{
  "model": "yolov8n",
  "task": "detect",
  "input": {
    "name": "images",
    "shape": [
      1,
      3,
      640,
      640
    ],
    "dtype": "float32",
    "layout": "NCHW (ONNX) / NHWC (TFLite)",
    "normalization": "x / 255.0"
  },
  "output": {
    "description": "YOLOv8 raw predictions: [batch, 4+nc, num_anchors]",
    "num_classes": 7,
    "anchors_at_imgsz_640": 8400,
    "needs_nms": true,
    "suggested_conf": 0.25,
    "suggested_iou": 0.45
  },
  "classes": {
    "0": "plastic",
    "1": "glass",
    "2": "metal",
    "3": "paper",
    "4": "cardboard",
    "5": "organic",
    "6": "other"
  },
  "bin_mapping": {
    "plastic": "recycling",
    "glass": "recycling",
    "metal": "recycling",
    "paper": "recycling",
    "cardboard": "recycling",
    "organic": "compost",
    "other": "general"
  }
}